---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { getAllSlugs, getPageMeta, buildDocPageBody } from '../../lib/docs';
import { STATIC_CONTENT } from '../../lib/static-content';

export function getStaticPaths() {
  return getAllSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const meta = getPageMeta(slug ?? null);

let body = '<p>Page under construction.</p>';

if (meta.static && STATIC_CONTENT[meta.static]) {
  body = STATIC_CONTENT[meta.static];
} else if (slug) {
  body = buildDocPageBody(slug) ?? body;
}
---

<DocsLayout title={meta.title} lead={meta.lead} breadcrumb={meta.breadcrumb}>
  <Fragment set:html={body} />
</DocsLayout>
